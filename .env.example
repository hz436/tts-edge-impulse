# Edge Impulse credentials
EDGE_IMPULSE_API_KEY=
EDGE_IMPULSE_PROJECT_ID=

# TTS settings (optional)
TTS_VOLUME=1.0        # Volume 0.0 - 1.0
TTS_SAMPLES_PER_LABEL=20   # Total audio samples to generate per label (base + augmented)

# Dataset settings (optional)
DATASET_DIR=dataset
SAMPLE_RATE=16000
SAMPLE_DURATION=1.5   # minimum seconds per audio clip; auto-extended for long phrases

# Training settings (optional — can also be overridden via CLI flags)
TRAINING_CYCLES=100       # number of training epochs
LEARNING_RATE=0.0005      # 0.0001–0.01 typical range
BATCH_SIZE=32             # samples per gradient update
AUTOTUNE_DSP=false        # set true to auto-tune MFCC/MFE params before each training run
